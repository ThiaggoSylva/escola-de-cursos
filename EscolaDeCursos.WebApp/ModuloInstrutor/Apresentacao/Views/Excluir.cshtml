@using EscolaDeCursos.WebApp.ModuloInstrutor.Apresentacao.Models
@model ExcluirInstrutorViewModel

@{
    ViewData["Title"] = "Excluir Instrutor";
}

<div class="page-header">

    <h2 class="titulo-pagina">
        Excluir Instrutor
    </h2>

    <a asp-action="Listar"
       class="btn btn-outline-secondary">
        Voltar
    </a>

</div>

<div class="card card-dashboard">

    <div class="card-body">

        <div class="alert alert-warning">

            Tem certeza que deseja excluir o instrutor:

            <strong>
                @Model.Nome
            </strong>?

        </div>

        <form asp-action="ConfirmarExclusao">

            <input type="hidden"
                   asp-for="Id" />

            <button type="submit"
                    class="btn btn-danger">
                Confirmar Exclusão
            </button>

            <a asp-action="Listar"
               class="btn btn-secondary">
                Cancelar
            </a>

        </form>

    </div>

</div>
