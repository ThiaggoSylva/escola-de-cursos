@using EscolaDeCursos.WebApp.ModuloInstrutor.Apresentacao.Models
@model FormularioInstrutorViewModel

<div class="card shadow-sm border-0 rounded-4">

    <div class="card-header bg-white border-0 pt-4">

        <h4 class="fw-bold text-primary mb-0">
            <i class="bi bi-mortarboard"></i>
            Dados do Instrutor
        </h4>

    </div>

    <div class="card-body p-4">

        <div class="row g-4">

            <div class="col-md-6">

                <label asp-for="Nome"
                       class="form-label fw-semibold">
                </label>

                <div class="input-group">

                    <span class="input-group-text">
                        <i class="bi bi-person"></i>
                    </span>

                    <input asp-for="Nome"
                           class="form-control" />

                </div>

            </div>

            <div class="col-md-6">

                <label asp-for="Email"
                       class="form-label fw-semibold">
                </label>

                <div class="input-group">

                    <span class="input-group-text">
                        <i class="bi bi-envelope"></i>
                    </span>

                    <input asp-for="Email"
                           class="form-control" />

                </div>

            </div>

            <div class="col-md-6">

                <label asp-for="Telefone"
                       class="form-label fw-semibold">
                </label>

                <div class="input-group">

                    <span class="input-group-text">
                        <i class="bi bi-telephone"></i>
                    </span>

                    <input asp-for="Telefone"
                           class="form-control" />

                </div>

            </div>

            <div class="col-md-6">

                <label asp-for="Especialidade"
                       class="form-label fw-semibold">
                </label>

                <div class="input-group">

                    <span class="input-group-text">
                        <i class="bi bi-award"></i>
                    </span>

                    <input asp-for="Especialidade"
                           class="form-control" />

                </div>

            </div>

        </div>

    </div>

</div>
