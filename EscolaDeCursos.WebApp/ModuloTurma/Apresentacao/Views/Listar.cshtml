@using EscolaDeCursos.WebApp.ModuloTurma.Apresentacao.Models
@model List<ListarTurmaViewModel>

@{
    ViewData["Title"] = "Turmas";
}

<div class="page-header">

    <h2 class="titulo-pagina">
        Turmas
    </h2>

    <a asp-action="Inserir"
       class="btn btn-primary">

        <i class="bi bi-plus-circle"></i>
        Nova Turma

    </a>

</div>

<div class="card card-dashboard">

    <div class="card-body">

        @if (!Model.Any())
        {
            <div class="alert alert-info">
                Nenhuma turma cadastrada.
            </div>
        }
        else
        {
            <table class="table table-hover align-middle">

                <thead>

                    <tr>
                        <th>Nome</th>
                        <th>Curso</th>
                        <th>Instrutor</th>
                        <th>Início</th>
                        <th>Término</th>
                        <th>Capacidade</th>
                        <th width="180">Ações</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var turma in Model)
                    {
                        <tr>

                            <td>@turma.Nome</td>

                            <td>@turma.Curso</td>

                            <td>@turma.Instrutor</td>

                            <td>@turma.DataInicio.ToString("dd/MM/yyyy")</td>

                            <td>@turma.DataTermino.ToString("dd/MM/yyyy")</td>

                            <td>@turma.CapacidadeMaxima</td>

                            <td>

                                <a asp-action="Editar"
                                   asp-route-id="@turma.Id"
                                   class="btn btn-sm btn-warning">

                                    <i class="bi bi-pencil"></i>

                                </a>

                                <a asp-action="Excluir"
                                   asp-route-id="@turma.Id"
                                   class="btn btn-sm btn-danger">

                                    <i class="bi bi-trash"></i>

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>
        }

    </div>

</div>
