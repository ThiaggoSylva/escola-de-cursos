@using EscolaDeCursos.WebApp.ModuloTurma.Apresentacao.Models
@model FormularioTurmaViewModel

<div asp-validation-summary="All" class="text-danger"></div>

<div class="mb-3">
    <label asp-for="Nome" class="form-label"></label>
    <input asp-for="Nome" class="form-control" />
    <span asp-validation-for="Nome" class="text-danger"></span>
</div>

<div class="row">

    <div class="col-md-6 mb-3">
        <label asp-for="CursoId" class="form-label"></label>
        <select asp-for="CursoId"
                asp-items="Model.Cursos"
                class="form-select">
            <option value="">Selecione um curso...</option>
        </select>
        <span asp-validation-for="CursoId" class="text-danger"></span>
    </div>

    <div class="col-md-6 mb-3">
        <label asp-for="InstrutorId" class="form-label"></label>
        <select asp-for="InstrutorId"
                asp-items="Model.Instrutores"
                class="form-select">
            <option value="">Selecione um instrutor...</option>
        </select>
        <span asp-validation-for="InstrutorId" class="text-danger"></span>
    </div>

</div>

<div class="row">

    <div class="col-md-4 mb-3">
        <label asp-for="DataInicio" class="form-label"></label>
        <input asp-for="DataInicio" class="form-control" />
        <span asp-validation-for="DataInicio" class="text-danger"></span>
    </div>

    <div class="col-md-4 mb-3">
        <label asp-for="DataTermino" class="form-label"></label>
        <input asp-for="DataTermino" class="form-control" />
        <span asp-validation-for="DataTermino" class="text-danger"></span>
    </div>

    <div class="col-md-4 mb-3">
        <label asp-for="CapacidadeMaxima" class="form-label"></label>
        <input asp-for="CapacidadeMaxima" class="form-control" />
        <span asp-validation-for="CapacidadeMaxima" class="text-danger"></span>
    </div>

</div>
