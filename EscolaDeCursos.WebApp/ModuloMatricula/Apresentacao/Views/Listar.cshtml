@using EscolaDeCursos.WebApp.ModuloMatricula.Apresentacao.Models
@model List<ListarMatriculaViewModel>

@{
    ViewData["Title"] = "Matrículas";
}

<div class="page-header">

    <h2 class="titulo-pagina">
        Matrículas
    </h2>

    <a asp-action="Inserir"
       class="btn btn-primary">

        <i class="bi bi-plus-circle"></i>
        Nova Matrícula

    </a>

</div>

<div class="card card-dashboard">

    <div class="card-body">

        @if (!Model.Any())
        {
            <div class="alert alert-info">
                Nenhuma matrícula cadastrada.
            </div>
        }
        else
        {
            <table class="table table-hover align-middle">

                <thead>

                    <tr>
                        <th>Aluno</th>
                        <th>Turma</th>
                        <th>Data da Matrícula</th>
                        <th>Situação</th>
                        <th width="180">Ações</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var matricula in Model)
                    {
                        <tr>

                            <td>@matricula.Aluno</td>

                            <td>@matricula.Turma</td>

                            <td>@matricula.DataMatricula.ToString("dd/MM/yyyy")</td>

                            <td>

                                @{
                                    string classeBadge = matricula.Situacao switch
                                    {
                                        "Ativa" => "bg-success",
                                        "Concluida" => "bg-primary",
                                        "Cancelada" => "bg-danger",
                                        "Trancada" => "bg-warning text-dark",
                                        _ => "bg-secondary"
                                    };
                                }

                                <span class="badge @classeBadge">
                                    @matricula.Situacao
                                </span>

                            </td>

                            <td>

                                <a asp-action="Editar"
                                   asp-route-id="@matricula.Id"
                                   class="btn btn-sm btn-warning">

                                    <i class="bi bi-pencil"></i>

                                </a>

                                <a asp-action="Excluir"
                                   asp-route-id="@matricula.Id"
                                   class="btn btn-sm btn-danger">

                                    <i class="bi bi-trash"></i>

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>
        }

    </div>

</div>
