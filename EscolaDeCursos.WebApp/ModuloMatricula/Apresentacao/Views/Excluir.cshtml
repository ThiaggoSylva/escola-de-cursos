@using EscolaDeCursos.WebApp.ModuloMatricula.Apresentacao.Models
@model ExcluirMatriculaViewModel

@{
    ViewData["Title"] = "Excluir Matrícula";
}

<div class="page-header">

    <h2 class="titulo-pagina">
        Excluir Matrícula
    </h2>

    <a asp-action="Listar"
       class="btn btn-outline-secondary">
        Voltar
    </a>

</div>

<div class="card card-dashboard">

    <div class="card-body">

        <div class="alert alert-warning">

            Tem certeza que deseja excluir a matrícula de
            <strong>@Model.Aluno</strong>
            na turma
            <strong>@Model.Turma</strong>?

        </div>

        <form asp-action="ConfirmarExclusao">

            <input type="hidden"
                   asp-for="Id" />

            <button type="submit"
                    class="btn btn-danger">
                Confirmar Exclusão
            </button>

            <a asp-action="Listar"
               class="btn btn-secondary">
                Cancelar
            </a>

        </form>

    </div>

</div>
