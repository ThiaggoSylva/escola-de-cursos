@using EscolaDeCursos.WebApp.ModuloMatricula.Apresentacao.Models
@model CadastrarMatriculaViewModel

@{
    ViewData["Title"] = "Nova Matrícula";
}

<div class="page-header">

    <h2 class="titulo-pagina">
        Nova Matrícula
    </h2>

    <a asp-action="Listar"
       class="btn btn-outline-secondary">
        Voltar
    </a>

</div>

<div class="card card-dashboard">

    <div class="card-body">

        <form method="post">

            <partial name="Formulario"
                     model="Model" />

            <div class="mt-3">

                <button type="submit"
                        class="btn btn-success">
                    Salvar
                </button>

                <a asp-action="Listar"
                   class="btn btn-secondary">
                    Cancelar
                </a>

            </div>

        </form>

    </div>

</div>
