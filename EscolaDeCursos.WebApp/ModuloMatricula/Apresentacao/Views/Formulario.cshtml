@using EscolaDeCursos.WebApp.ModuloMatricula.Apresentacao.Models
@model FormularioMatriculaViewModel

<div class="row">

    <div class="col-md-6">

        <div class="mb-3">

            <label asp-for="AlunoId"
                   class="form-label">
            </label>

            <select asp-for="AlunoId"
                    asp-items="Model.Alunos"
                    class="form-select">

                <option value="">
                    Selecione um aluno
                </option>

            </select>

            <span asp-validation-for="AlunoId"
                  class="text-danger">
            </span>

        </div>

    </div>

    <div class="col-md-6">

        <div class="mb-3">

            <label asp-for="TurmaId"
                   class="form-label">
            </label>

            <select asp-for="TurmaId"
                    asp-items="Model.Turmas"
                    class="form-select">

                <option value="">
                    Selecione uma turma
                </option>

            </select>

            <span asp-validation-for="TurmaId"
                  class="text-danger">
            </span>

        </div>

    </div>

</div>

<div class="row">

    <div class="col-md-4">

        <div class="mb-3">

            <label asp-for="DataMatricula"
                   class="form-label">
            </label>

            <input asp-for="DataMatricula"
                   type="date"
                   class="form-control" />

            <span asp-validation-for="DataMatricula"
                  class="text-danger">
            </span>

        </div>

    </div>

    <div class="col-md-4">

        <div class="mb-3">

            <label asp-for="Situacao"
                   class="form-label">
            </label>

            <select asp-for="Situacao"
                    class="form-select">

                <option value="Ativa">Ativa</option>
                <option value="Concluida">Concluída</option>
                <option value="Cancelada">Cancelada</option>

            </select>

            <span asp-validation-for="Situacao"
                  class="text-danger">
            </span>

        </div>

    </div>

</div>
