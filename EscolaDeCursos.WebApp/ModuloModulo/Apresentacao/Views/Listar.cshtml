@using EscolaDeCursos.WebApp.ModuloModulo.Apresentacao.Models
@model List<ListarModuloViewModel>

@{
    ViewData["Title"] = "Módulos";
}

<div class="page-header">

    <h2 class="titulo-pagina">
        Módulos
    </h2>

    <a asp-action="Inserir"
       class="btn btn-primary">

        <i class="bi bi-plus-circle"></i>
        Novo Módulo

    </a>

</div>

<div class="card card-dashboard">

    <div class="card-body">

        @if (!Model.Any())
        {
            <div class="alert alert-info">
                Nenhum módulo cadastrado.
            </div>
        }
        else
        {
            <table class="table table-hover align-middle">

                <thead>

                    <tr>
                        <th>Título</th>
                        <th>Ordem</th>
                        <th>Duração (horas)</th>
                        <th>Curso</th>
                        <th width="180">Ações</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var modulo in Model)
                    {
                        <tr>

                            <td>@modulo.Titulo</td>

                            <td>@modulo.Ordem</td>

                            <td>@modulo.Duracao</td>

                            <td>@modulo.Curso</td>

                            <td>

                                <a asp-action="Editar"
                                   asp-route-id="@modulo.Id"
                                   class="btn btn-sm btn-warning">

                                    <i class="bi bi-pencil"></i>

                                </a>

                                <a asp-action="Excluir"
                                   asp-route-id="@modulo.Id"
                                   class="btn btn-sm btn-danger">

                                    <i class="bi bi-trash"></i>

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>
        }

    </div>

</div>
