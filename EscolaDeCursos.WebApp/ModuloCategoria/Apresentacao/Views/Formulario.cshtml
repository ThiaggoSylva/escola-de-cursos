@using EscolaDeCursos.ModuloCategoria.Apresentacao.Models
@model FormularioCategoriaViewModel

<div class="card card-dashboard">

    <div class="card-body">

        <div class="row">

            <div class="col-md-12">

                <div class="mb-4">

                    <label asp-for="Titulo"
